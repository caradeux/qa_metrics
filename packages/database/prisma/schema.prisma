generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
}

model Permission {
  id       String           @id @default(cuid())
  resource String
  action   String
  roles    RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  active       Boolean  @default(true)
  allowOverallocation Boolean @default(false)
  isAutomation Boolean @default(false)   // marca: analista habilitado para QA Automatización
  specialties     Specialty[] @default([])
  assignedClients Client[]    @relation("AnalystClients")
  refreshToken String?
  createdAt    DateTime @default(now())
  clients           Client[]
  testers           Tester[]
  managedProjects   Project[]  @relation("ProjectManagerOfProject")
  dateChangeLogs    DateChangeLog[]
  createdActivities Activity[]
  flowpilotCredential FlowpilotCredential? @relation("UserFlowpilotCredential")
  flowpilotConnection FlowpilotConnection? @relation("UserFlowpilotConnection")
  flowpilotMappings   FlowpilotMapping[]   @relation("UserFlowpilotMappings")
  flowpilotSyncLogs   FlowpilotSyncLog[]   @relation("UserFlowpilotSyncLogs")
}

model Client {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  projects  Project[]
  analysts  User[]    @relation("AnalystClients")

  @@index([userId])
}

model Project {
  id         String      @id @default(cuid())
  name       String
  clientId   String
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  modality   Modality
  adoOrgUrl  String?
  adoProject String?
  adoToken   String?
  projectManagerId String?
  projectManager   User?    @relation("ProjectManagerOfProject", fields: [projectManagerId], references: [id])
  createdAt  DateTime    @default(now())
  testers    Tester[]
  stories    UserStory[]
  testLines  TestLine[]

  @@index([clientId])
  @@index([projectManagerId])
}

model Tester {
  id          String             @id @default(cuid())
  name        String
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?              @relation(fields: [userId], references: [id])
  allocation  Int                @default(100)
  records     DailyRecord[]
  assignments TesterAssignment[]
  activities  Activity[]
  automationAssignments AutomationAssignment[]
  automationRecords     AutomationRecord[]

  @@index([projectId])
}

model TesterAssignment {
  id             String           @id @default(cuid())
  testerId       String
  tester         Tester           @relation(fields: [testerId], references: [id], onDelete: Cascade)
  storyId        String
  story          UserStory        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  cycleId        String
  cycle          TestCycle        @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime?
  status         AssignmentStatus @default(REGISTERED)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  statusLogs     AssignmentStatusLog[]
  dailyRecords   DailyRecord[]
  phases         AssignmentPhase[]
  activities     Activity[]

  @@unique([testerId, storyId, cycleId])
  @@index([testerId])
  @@index([storyId])
  @@index([cycleId])
}

model AssignmentStatusLog {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   TesterAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  status       AssignmentStatus
  changedAt    DateTime         @default(now())

  @@index([assignmentId])
}

model TestCycle {
  id        String         @id @default(cuid())
  name      String
  storyId   String
  story     UserStory      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  startDate DateTime?
  endDate   DateTime?
  assignments TesterAssignment[]

  @@index([storyId])
}

model UserStory {
  id                  String             @id @default(cuid())
  externalId          String?
  title               String
  designComplexity    Complexity         @default(MEDIUM)
  executionComplexity Complexity         @default(MEDIUM)
  projectId           String
  project             Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments         TesterAssignment[]
  cycles              TestCycle[]

  @@index([projectId])
}

model DailyRecord {
  id           String            @id @default(cuid())
  testerId     String
  tester       Tester            @relation(fields: [testerId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   TesterAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  date         DateTime          @db.Date
  designed     Int               @default(0)
  executed     Int               @default(0)
  defects      Int               @default(0)
  notes        String?                                   // nota interna del analista (no aparece en PPTX)
  source       String            @default("MANUAL")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([assignmentId, date])
  @@index([assignmentId])
  @@index([testerId])
  @@index([date])
}

model Holiday {
  date DateTime @id @db.Date
  name String
}

model DateChangeLog {
  id         String              @id @default(cuid())
  entityType DateChangeEntityType
  entityId   String
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  field      String              // startDate | endDate
  oldValue   DateTime?
  newValue   DateTime?
  reason     String              // mínimo 10 caracteres, validado en API
  createdAt  DateTime            @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

enum DateChangeEntityType {
  CYCLE
  ASSIGNMENT
  PHASE
}

enum Specialty {
  QA_MANUAL
  QA_AUTOMATION
  PERFORMANCE
}

enum Modality {
  AZURE_DEVOPS
  MANUAL
  AUTOMATION
}

enum Complexity {
  HIGH
  MEDIUM
  LOW
}

enum AssignmentPhaseType {
  ANALYSIS
  TEST_DESIGN
  EXECUTION
}

model AssignmentPhase {
  id           String               @id @default(cuid())
  assignmentId String
  assignment   TesterAssignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  phase        AssignmentPhaseType
  startDate    DateTime             @db.Date
  endDate      DateTime             @db.Date

  @@unique([assignmentId, phase])
  @@index([assignmentId])
}

enum AssignmentStatus {
  REGISTERED
  ANALYSIS
  TEST_DESIGN
  WAITING_QA_DEPLOY
  EXECUTION
  RETURNED_TO_DEV
  WAITING_UAT
  UAT
  PRODUCTION
  ON_HOLD
}

enum AutomationStatus {
  ACTIVE        // building / extending the suite
  MAINTENANCE   // only refactor / fixes
  PAUSED
  DONE
}

model ActivityCategory {
  id         String                    @id @default(cuid())
  name       String                    @unique
  color      String?
  active     Boolean                   @default(true)
  bandType   ActivityCategoryBandType  @default(OTHER)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  activities Activity[]
}

enum ActivityCategoryBandType {
  USER_MEETING      // "Reunión con usuario", Aceptación CP, Presentación UAT
  DEV_MEETING       // "Reunión con desarrollo", Daily Scrum
  TRAINING          // Inducción, Capacitación, Capacitacion Inovabiz
  ABSENCE           // Vacaciones, Licencia, Permiso (resta capacidad)
  OTHER             // Sin clasificación — suma a "Otras actividades"
}

model Activity {
  id           String            @id @default(cuid())
  testerId     String
  categoryId   String
  assignmentId String?
  testLineId   String?
  startAt      DateTime
  endAt        DateTime
  notes        String?
  createdById  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tester     Tester            @relation(fields: [testerId], references: [id], onDelete: Cascade)
  category   ActivityCategory  @relation(fields: [categoryId], references: [id])
  assignment TesterAssignment? @relation(fields: [assignmentId], references: [id])
  testLine   TestLine?         @relation(fields: [testLineId], references: [id])
  createdBy  User              @relation(fields: [createdById], references: [id])

  @@index([testerId, startAt])
  @@index([testerId, endAt])
  @@index([assignmentId])
  @@index([testLineId])
}

model FlowpilotCredential {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation("UserFlowpilotCredential", fields: [userId], references: [id], onDelete: Cascade)
  passwordEnc String
  capturedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FlowpilotConnection {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation("UserFlowpilotConnection", fields: [userId], references: [id], onDelete: Cascade)
  flowpilotUserId Int?
  enabled         Boolean   @default(true)
  valid           Boolean   @default(false)
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model FlowpilotMapping {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserFlowpilotMappings", fields: [userId], references: [id], onDelete: Cascade)
  kind         String
  entityType   String
  clientId     Int
  clientName   String
  contractId   Int?
  projectId    Int?
  entityName   String
  taskTypeId   Int
  taskTypeName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, kind])
  @@index([userId])
}

model FlowpilotSyncLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserFlowpilotSyncLogs", fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  entryIds    Int[]
  hoursTotal  Float
  status      String
  payloadHash String
  sentAt      DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// Configuración editable de la integración FlowPilot (fila única, id="singleton").
// Si no existe, se usa FLOWPILOT_BASE_URL del entorno como fallback.
model FlowpilotSetting {
  id        String   @id
  baseUrl   String
  updatedAt DateTime @updatedAt
}

// ── QA Automation track ──────────────────────────────────────────────
// Sibling hierarchy to UserStory→TestCycle→TesterAssignment→DailyRecord.
// The unit of work is a Test Line (suite), not a User Story.

model TestLine {
  id          String                 @id @default(cuid())
  externalId  String?
  name        String                 // e.g. "Regresión Checkout", "Smoke API Pagos"
  complexity  Complexity             @default(MEDIUM)
  projectId   String
  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments AutomationAssignment[]
  activities  Activity[]

  @@index([projectId])
}

model AutomationAssignment {
  id         String             @id @default(cuid())
  testerId   String
  tester     Tester             @relation(fields: [testerId], references: [id], onDelete: Cascade)
  testLineId String
  testLine   TestLine           @relation(fields: [testLineId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime?
  status     AutomationStatus   @default(ACTIVE)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  records    AutomationRecord[]

  @@unique([testerId, testLineId])
  @@index([testerId])
  @@index([testLineId])
}

model AutomationRecord {
  id                String               @id @default(cuid())
  testerId          String
  tester            Tester               @relation(fields: [testerId], references: [id], onDelete: Cascade)
  assignmentId      String
  assignment        AutomationAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  date              DateTime             @db.Date
  scriptsCreated    Int                  @default(0)
  scriptsRefactored Int                  @default(0)
  scriptsFixed      Int                  @default(0)
  execTotal         Int                  @default(0)
  execPassed        Int                  @default(0)
  execFailed        Int                  @default(0)
  notes             String?
  source            String               @default("MANUAL")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([assignmentId, date])
  @@index([assignmentId])
  @@index([testerId])
  @@index([date])
}
